# Dependencies
node_modules/

# Python bytecode caches (e.g. from running/importing build/engines/*.py helpers)
__pycache__/
*.pyc

# Build outputs
build/out/
build/work/
dist/

# Downloaded source caches (build/sources/pins.lock stays tracked)
build/sources/cache/

# OS / editor noise
.DS_Store

# TypeScript / test artifacts
# runtime/ tsc output (.js + .d.ts). Also matched by the dist/ rule above;
# listed explicitly so the intent is unambiguous — build artifacts are never
# committed (DESIGN.md §2 reproducibility).
runtime/dist/
*.tsbuildinfo
coverage/
playwright-report/
test-results/

# npm debug logs
npm-debug.log*

# Local Claude settings (shared .claude/settings.json stays tracked)
.claude/settings.local.json
.claude/scheduled_tasks.lock
