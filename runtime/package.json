{
  "name": "wasmtex",
  "version": "0.1.0",
  "type": "module",
  "description": "Typed, framework-free ESM runtime that typesets TeX (current TeX Live, WebAssembly) to PDF in a Worker: job objects, streaming logs, structured diagnostics, real cancellation.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bofeizhu/wasmtex.git",
    "directory": "runtime"
  },
  "homepage": "https://github.com/bofeizhu/wasmtex#readme",
  "bugs": "https://github.com/bofeizhu/wasmtex/issues",
  "keywords": [
    "tex",
    "latex",
    "xetex",
    "pdftex",
    "texlive",
    "wasm",
    "webassembly",
    "pdf",
    "typesetting"
  ],
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "!dist/node-harness.mjs",
    "!dist/node-harness.mjs.map"
  ],
  "scripts": {
    "build": "tsc && npm run build:worker && npm run build:node-harness",
    "build:worker": "esbuild worker/entry.ts --bundle --format=iife --target=es2022 --platform=browser --outfile=dist/worker.js --sourcemap",
    "build:node-harness": "esbuild node/harness.ts --bundle --format=esm --target=es2022 --platform=node --outfile=dist/node-harness.mjs --sourcemap",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "esbuild": "0.28.1",
    "typescript": "5.9.3",
    "vitest": "3.2.7"
  }
}
