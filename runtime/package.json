{
  "name": "wasmtex",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Typed, framework-free ESM runtime that typesets TeX to PDF in a Worker (DESIGN.md §5). Scaffold — not yet published.",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "typescript": "5.9.3",
    "vitest": "3.2.7"
  }
}
