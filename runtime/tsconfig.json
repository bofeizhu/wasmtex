{
  // Build config for the wasmtex package: `npm run build` emits with this config.
  // Scope is src/ + worker/; test/ is deliberately NOT in `include`, so tests are
  // never emitted to dist/. Tests ARE type-checked — by tsconfig.test.json (which
  // extends this file and adds test/) through `npm run typecheck`. (Vitest's
  // `typecheck` mode is a type-assertion feature, not a general typechecker: it
  // does not fail on ordinary type errors in test bodies, so it is not relied on
  // for correctness here.)
  //
  // moduleResolution "bundler": wasmtex is authored as ESM and consumed through
  // its package.json `exports` map by bundlers and, in tests, by vitest/esbuild.
  // "bundler" models that resolution. Source relative specifiers carry explicit
  // ".js" extensions (`./protocol.js`, `./client.js`, …) even though the files on
  // disk are ".ts": "bundler" resolution maps a ".js" specifier onto its sibling
  // ".ts" source, so tsc compiles unchanged — while the EMITTED dist/ keeps those
  // same ".js" specifiers, which lets the published package load as-is under
  // native Node ESM AND native-browser ESM (no bundler, no import map needed). So
  // we do NOT need "nodenext": "bundler" + explicit ".js" specifiers already
  // yields portable output. (DESIGN.md §5.2: runtime targets Worker + fetch + WASM.)
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    // Empty on purpose: src/ and worker/ target the browser/worker world
    // (DESIGN §5.2 — Worker + fetch + WebAssembly, no Node). Node ambient
    // globals leaking here would let Buffer/process slip past tsc and break
    // at runtime. Only test/ gets node types (tsconfig.test.json).
    "types": [],
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src", "worker"],
  "exclude": ["dist", "node_modules"]
}
